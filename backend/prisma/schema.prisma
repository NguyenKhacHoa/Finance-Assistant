generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════
// ENUMS
// ══════════════════════════════════════════════════════════════

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  INCOME    // Thu nhập thông thường
  EXPENSE   // Chi tiêu
  LUONG     // Phân bổ lương (salary distribution)
  TRANSFER  // Chuyển giữa các hũ
}

// Danh mục chi tiêu/thu nhập — AI sẽ tự phân loại nếu để null
enum TransactionCategory {
  Food          // Ăn uống
  Entertainment // Giải trí
  Utility       // Tiện ích (điện, nước, internet)
  Education     // Học tập
  Transport     // Di chuyển
  Healthcare    // Sức khỏe
  Salary        // Lương
  Shopping      // Mua sắm
  Investment    // Đầu tư
  Other         // Khác
}

// Nguồn tiền của giao dịch
enum TransactionSource {
  CASH    // Tiền mặt
  BANK    // Chuyển khoản ngân hàng
  WALLET  // Ví điện tử (MoMo, ZaloPay, v.v.)
  CARD    // Thẻ tín dụng / ghi nợ
  SYSTEM  // Nội bộ hệ thống (phân bổ tự động)
}

// ══════════════════════════════════════════════════════════════
// CORE MODELS
// ══════════════════════════════════════════════════════════════

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  name               String?
  phone              String?  @unique
  avatarUrl          String?
  role               Role     @default(USER)
  rewardPoints       Int      @default(0)
  loginStreak        Int      @default(0)

  /// Số dư đang nằm ngoài các hũ (chưa được phân bổ).
  /// Tăng khi: nạp tiền trực tiếp, surplus sau khi chia lương.
  /// Giảm khi: phân bổ vào hũ, nạp vào mục tiêu tiết kiệm.
  unallocatedBalance Decimal  @default(0)

  // ── Auth ──────────────────────────────────────────────────
  passwordHash   String?   // null nếu đăng ký bằng Google / Phone OTP
  googleId       String?   @unique
  isVerified     Boolean   @default(false)
  verifyToken    String?   // token xác thực email
  verifyExpiry   DateTime?
  resetToken     String?   // token đặt lại mật khẩu
  resetExpiry    DateTime?

  // ── Bank Link Integration ─────────────────────────────────────────
  bankLinked     Boolean   @default(false)
  webhookToken   String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Relations (tất cả Cascade để deleteAccount hoạt động đúng) ──
  pockets         Pocket[]
  transactions    Transaction[]
  survivalConfigs SurvivalConfig[]
  goals           SavingsGoal[]
  badges          UserBadge[]
  fixedExpenses   FixedExpense[]
  pointLogs       PointLog[]
}

// ── FixedExpense ───────────────────────────────────────────────
model FixedExpense {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  amount     Decimal
  autoDeduct Boolean  @default(true)
  pocketId   String?
  /// onDelete: SetNull — nếu hũ bị xóa, chi phí cố định vẫn tồn tại nhưng không gắn hũ.
  pocket     Pocket?  @relation(fields: [pocketId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Pocket ────────────────────────────────────────────────────
model Pocket {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  shortName   String?
  percentage  Decimal
  balance     Decimal  @default(0)
  isEssential Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions  Transaction[]
  fixedExpenses FixedExpense[]
}

// ── Transaction ───────────────────────────────────────────────
model Transaction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  pocketId String?
  /// onDelete: SetNull — nếu hũ bị xóa, giao dịch vẫn giữ lại lịch sử.
  pocket   Pocket? @relation(fields: [pocketId], references: [id], onDelete: SetNull)

  amount Decimal
  type   TransactionType

  /// Tiêu đề ngắn tự đặt (ví dụ: "Ăn trưa", "Học phí tháng 4")
  title  String

  /// Nội dung mô tả chi tiết giao dịch (tương đương trường "nội dung chuyển khoản").
  /// Có thể để trống; AI sẽ đọc trường này để phân loại category.
  description String?

  /// Danh mục — optional để AI phân loại tự động sau khi tạo.
  /// Nếu người dùng chọn thủ công, lưu luôn giá trị đó.
  category TransactionCategory?

  /// Nguồn tiền của giao dịch (tiền mặt, ngân hàng, ví điện tử, v.v.)
  source TransactionSource @default(SYSTEM)

  /// Mã giao dịch từ ngân hàng dùng để chống trùng lặp Webhook
  bankTransactionId String? @unique

  encryptedData String? // IV + Tag + Ciphertext (mã hoá dữ liệu nhạy cảm)
  metadata      Json?   // Dữ liệu tuỳ chỉnh (AI breakdown, batch ID, v.v.)

  createdAt DateTime @default(now())

  goalId String?
  /// onDelete: SetNull — nếu mục tiêu bị xóa, giao dịch vẫn giữ lịch sử.
  goal   SavingsGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
}

// ── SurvivalConfig ────────────────────────────────────────────
model SurvivalConfig {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isActive            Boolean  @default(false)
  triggerThreshold    Decimal  @default(2000000)
  disableNonEssential Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

// ══════════════════════════════════════════════════════════════
// GAMIFICATION MODULE
// ══════════════════════════════════════════════════════════════

model SavingsGoal {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetAmount  Decimal
  currentAmount Decimal   @default(0)
  deadline      DateTime?
  /// ACTIVE | COMPLETED | FAILED
  status        String    @default("ACTIVE")
  title         String
  icon          String    @default("Target")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions Transaction[]
}

model Badge {
  id             String   @id @default(uuid())
  name           String   @unique
  description    String
  icon           String
  requiredPoints Int      @default(0)
  createdAt      DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model PointLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int      // + tăng, - giảm
  reason    String   // mô tả lý do
  createdAt DateTime @default(now())
}
